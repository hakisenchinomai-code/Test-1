--// =====================
--// AUTO EQUIP
--// =====================
local function equipAllTools()
    local char = lp.Character
    if not char then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    for _, tool in pairs(lp.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            pcall(function()
                hum:EquipTool(tool)
            end)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.3)
        if autoEquip then equipAllTools() end
    end
end)

lp.Backpack.ChildAdded:Connect(function()
    if autoEquip then
        task.wait(0.1)
        equipAllTools()
    end
end)

lp.CharacterAdded:Connect(function(char)
    repeat task.wait() until char:FindFirstChildOfClass("Humanoid")
    task.wait(0.2)

    if autoEquip then equipAllTools() end

    -- auto avatar
    if avatarName ~= "" then
        task.wait(0.5)
        pcall(function()
            local id = Players:GetUserIdFromNameAsync(avatarName)
            local desc = Players:GetHumanoidDescriptionFromUserId(id)
            char:FindFirstChildOfClass("Humanoid"):ApplyDescription(desc)
        end)
    end
end)

--// =====================
--// AUTO CLICK
--// =====================
task.spawn(function()
    while true do
        task.wait(0.05)
        if autoClick then
            if UserInputService:GetFocusedTextBox() then continue end

            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:Button1Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                task.wait()
                VirtualUser:Button1Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            end)
        end
    end
end)

--// =====================
--// GOD MODE
--// =====================
task.spawn(function()
    while true do
        task.wait(0.1)

        local char = lp.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum and godMode then
                hum.Health = hum.MaxHealth
            end
        end
    end
end)

