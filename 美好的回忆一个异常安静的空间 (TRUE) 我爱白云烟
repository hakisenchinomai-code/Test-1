local function showText(t, st, laugh)
    main.Text = t
    sub.Text = st
    main.TextColor3 = laugh and Color3.fromRGB(255,0,0) or Color3.new(1,1,1)

    if laugh then
        task.spawn(function()
            for i=1,20 do
                main.Position = UDim2.new(0.5,-250 + math.random(-3,3),0.75 + math.random(-3,3),0)
                task.wait(0.03)
            end
            main.Position = UDim2.new(0.5,-250,0.75,0)
        end)

        local s = Instance.new("Sound", workspace)
        s.SoundId = "rbxassetid://140445930084397"
        s.Volume = 2
        s:Play()
        game:GetService("Debris"):AddItem(s,5)
    end
end

