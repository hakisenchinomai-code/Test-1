--// AUTO EQUIP
local function equipAllTools()
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    for _, tool in pairs(lp.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            hum:EquipTool(tool)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.3)
        if autoEquip then equipAllTools() end
    end
end)

lp.CharacterAdded:Connect(function(char)
    task.wait(0.2)
    if autoEquip then equipAllTools() end
end)

--// AUTO CLICK
task.spawn(function()
    while true do
        task.wait(0.05)
        if autoClick and not UserInputService:GetFocusedTextBox() then
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:Button1Down(Vector2.new(), workspace.CurrentCamera.CFrame)
                task.wait()
                VirtualUser:Button1Up(Vector2.new(), workspace.CurrentCamera.CFrame)
            end)
        end
    end
end)

--// GOD MODE
task.spawn(function()
    while true do
        task.wait(0.1)
        if godMode then
            local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.Health = hum.MaxHealth end
        end
    end
end)

--// ANTI AFK
lp.Idled:Connect(function()
    if antiAFK then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end)

--// AVATAR
local function applyAvatar(name)
    local ok,id = pcall(function()
        return Players:GetUserIdFromNameAsync(name)
    end)
    if not ok then return end

    local ok2,desc = pcall(function()
        return Players:GetHumanoidDescriptionFromUserId(id)
    end)
    if not ok2 then return end

    local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum:ApplyDescription(desc) end
end

--// =====================
--// HIM EFFECT (FADE)
--// =====================
local playing = false

local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local main = Instance.new("TextLabel", gui)
main.Size = UDim2.new(0,500,0,40)
main.Position = UDim2.new(0.5,-250,0.75,0)
main.BackgroundTransparency = 1
main.TextScaled = true
main.Font = Enum.Font.GothamBold
main.TextTransparency = 1

local sub = Instance.new("TextLabel", gui)
sub.Size = UDim2.new(0,500,0,25)
sub.Position = UDim2.new(0.5,-250,0.75,35)
sub.BackgroundTransparency = 1
sub.TextScaled = true
sub.Font = Enum.Font.Gotham
sub.TextColor3 = Color3.fromRGB(200,200,200)
sub.TextTransparency = 1

local function fadeText(text1,text2,isLaugh)
    main.Text = text1
    sub.Text = text2
    main.TextColor3 = isLaugh and Color3.fromRGB(255,0,0) or Color3.new(1,1,1)

    -- fade in
    TweenService:Create(main,TweenInfo.new(0.5),{TextTransparency=0}):Play()
    TweenService:Create(sub,TweenInfo.new(0.5),{TextTransparency=0}):Play()

    if isLaugh then
        -- rung + sound cùng lúc
        task.spawn(function()
            local s = Instance.new("Sound", workspace)
            s.SoundId = "rbxassetid://140445930084397"
            s.Volume = 2
            s:Play()
            game:GetService("Debris"):AddItem(s,5)
        end)

        task.spawn(function()
            for i=1,20 do
                main.Position = UDim2.new(0.5,-250 + math.random(-4,4),0.75 + math.random(-3,3),0)
                task.wait(0.03)
            end
            main.Position = UDim2.new(0.5,-250,0.75,0)
        end)
    end

    task.wait(2.5)

    -- fade out
    TweenService:Create(main,TweenInfo.new(0.5),{TextTransparency=1}):Play()
    TweenService:Create(sub,TweenInfo.new(0.5),{TextTransparency=1}):Play()

    task.wait(0.6)
end

